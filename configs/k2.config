# ============================================
# 目标平台设置 —— 修改为 K2 (MT7620)
# ============================================
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7620=y
CONFIG_TARGET_ramips_mt7620_DEVICE_phicomm_k2-v22.5=y

# ============================================
# 闭源无线驱动 —— 更换为 MT7620 专用驱动
# ============================================
# CONFIG_PACKAGE_kmod-mt7620 is not set
# CONFIG_PACKAGE_kmod-mt7612e is not set          * 5G 芯片驱动，视情况添加
# CONFIG_PACKAGE_uci2dat is not set               * 配置转换工具

# ============================================
# 硬件加速（HWNAT）—— 提升转发性能，闭源驱动配合使用效果更好[reference:1][reference:2]
# ============================================
# CONFIG_PACKAGE_kmod-hw_nat is not set
# CONFIG_PACKAGE_kmod-fast-classifier is not set
# CONFIG_PACKAGE_kmod-shortcut-fe is not set
# CONFIG_PACKAGE_kmod-shortcut-fe-cm is not set

# ============================================
# 基础网络功能
# ============================================
CONFIG_PACKAGE_dnsmasq=y        # 不用 full 版
# CONFIG_PACKAGE_firewall is not set
CONFIG_PACKAGE_iptables=y
# CONFIG_PACKAGE_dnsmasq-full is not set
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set

# ============================================
# 基础网络功能 (最小化) 移除完整版dnsmasq，改用更轻量的dnsmasq-dhcpv6：你当前配置的dnsmasq（CONFIG_PACKAGE_dnsmasq=y）体积较大。可将其替换为只包含DHCP和DNS缓存功能的dnsmasq-dhcpv6，能显著节省空间。
# 移除firewall和iptables，改用nftables：传统的iptables框架较为臃肿。新一代的nftables更轻量、高效，是未来趋势，很适合资源受限的设备。
# ============================================
# CONFIG_PACKAGE_dnsmasq-dhcpv6 is not set        # 轻量级 DHCP/DNS
# CONFIG_PACKAGE_nftables is not set              # 新一代防火墙
# CONFIG_PACKAGE_firewall4 is not set             # 基于 nftables 的防火墙

# ============================================
# 文件系统与 USB 支持（K2P 改过 USB 的可以启用）
# ============================================
# CONFIG_PACKAGE_kmod-usb-core is not set
# CONFIG_PACKAGE_kmod-usb2 is not set
# CONFIG_PACKAGE_kmod-usb3 is not set
# CONFIG_PACKAGE_kmod-usb-storage is not set
# CONFIG_PACKAGE_kmod-fs-ext4 is not set
# CONFIG_PACKAGE_kmod-fs-vfat is not set
# CONFIG_PACKAGE_kmod-fs-ntfs is not set
# CONFIG_PACKAGE_block-mount is not set

# ============================================
# LuCI Web 界面与主题
# ============================================
CONFIG_PACKAGE_luci=y
# CONFIG_PACKAGE_luci-ssl-openssl is not set
# CONFIG_PACKAGE_luci-theme-argon is not set          * Argon 漂亮主题 *
# CONFIG_PACKAGE_luci-app-argon-config is not set     * Argon 主题设置 *
CONFIG_LUCI_LANG_zh_Hans=y                 # 简体中文

# ============================================
# ZeroTier 插件 
# ============================================
# CONFIG_PACKAGE_luci-app-zerotier is not set

# ============================================
# 常用插件（按需增删，y=启用，n=禁用）
# ============================================
# CONFIG_PACKAGE_luci-app-upnp is not set             * UPnP 自动端口转发
# CONFIG_PACKAGE_luci-app-autoreboot= is not set      * 定时重启 *
# CONFIG_PACKAGE_luci-app-filetransfer is not set     * 文件传输（上传 ipk 安装包）*
# CONFIG_PACKAGE_luci-app-ttyd is not set             * 网页终端 *
# CONFIG_PACKAGE_luci-app-wol is not set              * 网络唤醒 *

# ============================================
# 系统工具
# ============================================
# CONFIG_PACKAGE_curl is not set
# CONFIG_PACKAGE_wget-ssl is not set
# CONFIG_PACKAGE_vim-fuller is not set
# CONFIG_PACKAGE_htop is not set
# CONFIG_PACKAGE_nano is not set

# ============================================
# IPv6 支持（如需 IPv6 取消下面注释）
# ============================================
# CONFIG_PACKAGE_ipv6helper is not set
# CONFIG_PACKAGE_odhcp6c is not set
# CONFIG_PACKAGE_odhcpd-ipv6only is not set

# ============================================
# 用 wpad-mini 替换完整版 wpad
# ============================================
CONFIG_PACKAGE_wpad-mini=y
# CONFIG_PACKAGE_wpad is not set
# CONFIG_PACKAGE_wpad-basic is not set

# ============================================
# 内核级精简
# ============================================
# CONFIG_KERNEL_CRASHLOG is not set
# CONFIG_KERNEL_SWAP is not set
# CONFIG_KERNEL_DEBUG_INFO is not set
# CONFIG_KERNEL_MAGIC_SYSRQ is not set
# CONFIG_KERNEL_ELF_CORE is not set
CONFIG_STRIP_KERNEL_EXPORTS=y
# CONFIG_USE_MKLIBS is not set

# ============================================
# 禁用非必要系统服务与内核驱动
# ============================================

# 1. 禁用系统日志守护进程 logd
# CONFIG_PACKAGE_logd is not set

# 2. 禁用音频支持
# CONFIG_PACKAGE_kmod-sound-core is not set

# 3. 禁用视频支持
# CONFIG_PACKAGE_kmod-video-core is not set

# ============================================
# 编译优化 (关键！)
# ============================================
CONFIG_CC_OPTIMIZE_FOR_SIZE=y          * 以体积最小为目标编译
# CONFIG_DEBUG_KERNEL is not set       * 移除内核调试信息
# CONFIG_DEBUG_INFO is not set

# ============================================
# 固件压缩 (关键优化！)
# ============================================
CONFIG_TARGET_IMAGES_USE_LZMA=y
# CONFIG_TARGET_IMAGES_USE_XZ is not set
CONFIG_IMAGEOPT=y

# ============================================
# 其他优化
# ============================================
CONFIG_VERSIONOPT=y
CONFIG_VERSION_DIST="ImmortalWrt"
CONFIG_VERSION_REPO="https://github.com/immortalwrt/immortalwrt"
CONFIG_VERSION_NUMBER="24.10"
CONFIG_VERSION_CODE=""
CONFIG_VERSION_HOME_URL=""
CONFIG_VERSION_MANUFACTURER_URL=""
CONFIG_VERSION_BUG_URL=""
CONFIG_VERSION_SUPPORT_URL=""
